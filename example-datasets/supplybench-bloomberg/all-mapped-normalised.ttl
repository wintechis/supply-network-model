qudt:Unit  rdf:type       rdfs:Class;
        rdfs:comment      "A unit of measure, or unit, is a particular quantity value that has been chosen as a scale for measuring other quantities the same kind (more generally of equivalent dimension)."@en;
        rdfs:isDefinedBy  qudt:;
        rdfs:label        "Unit"@en .

sn:into  rdf:type         rdf:Property , qb:DimensionProperty;
        rdfs:comment      "Links the entity that is the target of a directed supply flow between two entities. This property is abstract, i.e. abstraction-specific subproperties are expected."@en;
        rdfs:domain       sn:SupplyFlow;
        rdfs:isDefinedBy  sn:;
        rdfs:label        "into"@en;
        rdfs:range        sn:Entity .

sn:from  rdf:type         rdf:Property , qb:DimensionProperty;
        rdfs:comment      "Links the entity that is the origin/source of a directed supply flow between two entities. This property is abstract, i.e. abstraction-specific subproperties are expecteda."@en;
        rdfs:domain       sn:SupplyFlow;
        rdfs:isDefinedBy  sn:;
        rdfs:label        "from"@en;
        rdfs:range        sn:Entity .

sn:abstractSubstitute
        rdf:type            rdf:Property;
        rdfs:comment        "Links an associated entity on another abstraction. This property is abstract, i.e. abstraction-specific subproperties are expected."@en;
        rdfs:domain         sn:Entity;
        rdfs:isDefinedBy    sn:;
        rdfs:label          "abstract substitute"@en;
        rdfs:range          sn:Entity;
        rdfs:subPropertyOf  skos:broader .

sn:Entity  rdf:type       rdfs:Class;
        rdfs:comment      "An entity that can represent a vertex in a supply network on an abstraction. This class is abstract, i.e. abstraction-specific subclasses are expected."@en;
        rdfs:isDefinedBy  sn:;
        rdfs:label        "Entity"@en;
        rdfs:subClassOf   skos:Concept .

