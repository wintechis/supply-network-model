PREFIX :         <https://purl.org/supply-network/examples/>
PREFIX bbox:     <https://inspirewrap.ontologycentral.com/vocab/bbox#>
PREFIX cosn:     <https://paul.ti.rw.fau.de/~ju32haqi/supply-networks/abstraction-examples/cosn-ontology#>
PREFIX csn:      <https://paul.ti.rw.fau.de/~ju32haqi/supply-networks/abstraction-examples/csn-ontology#>
PREFIX cur:      <http://qudt.org/vocab/currency/>
PREFIX dblp:     <https://dblp.org/rdf/schema#>
PREFIX dbo:      <https://dbpedia.org/ontology/>
PREFIX dct:      <http://purl.org/dc/terms/>
PREFIX esn:      <https://paul.ti.rw.fau.de/~ju32haqi/supply-networks/abstraction-examples/esn-ontology#>
PREFIX ex:       <http://example.com/>
PREFIX foaf:     <http://xmlns.com/foaf/0.1/>
PREFIX fssn:     <https://paul.ti.rw.fau.de/~ju32haqi/supply-networks/abstraction-examples/fssn-ontology#>
PREFIX geo:      <http://www.w3.org/2003/01/geo/wgs84_pos#>
PREFIX geonames: <http://www.geonames.org/ontology#>
PREFIX gml:      <http://www.opengis.net/gml/3.2>
PREFIX greg:     <http://www.w3.org/ns/time/gregorian/>
PREFIX isn:      <https://paul.ti.rw.fau.de/~ju32haqi/supply-networks/abstraction-examples/isn-ontology#>
PREFIX locn:     <http://www.w3.org/ns/locn#>
PREFIX nvidia:   <https://solid.iis.fraunhofer.de/oe-40200/2024/10/velektronik-graph-clean/company/weQ21.ttl#>
PREFIX org:      <http://www.w3.org/ns/org#>
PREFIX org1:     <https://www.w3.org/ns/org#>
PREFIX owl:      <http://www.w3.org/2002/07/owl#>
PREFIX prov:     <http://www.w3.org/ns/prov#>
PREFIX ptsn:     <https://paul.ti.rw.fau.de/~ju32haqi/supply-networks/abstraction-examples/ptsn-ontology#>
PREFIX qb:       <http://purl.org/linked-data/cube#>
PREFIX qudt:     <http://qudt.org/schema/qudt/>
PREFIX rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:     <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sb:       <https://purl.org/supplybench#>
PREFIX schema:   <https://schema.org/>
PREFIX skos:     <http://www.w3.org/2004/02/skos/core#>
PREFIX sn:       <https://purl.org/supply-network/onto#>
PREFIX sosa:     <http://www.w3.org/ns/sosa/>
PREFIX taiwan:   <https://solid.iis.fraunhofer.de/oe-40200/2024/10/velektronik-graph-clean/region/wdQ865.ttl#>
PREFIX time:     <http://www.w3.org/2006/time#>
PREFIX tsmc:     <https://solid.iis.fraunhofer.de/oe-40200/2024/10/velektronik-graph-clean/company/weQ20.ttl#>
PREFIX usa:      <https://solid.iis.fraunhofer.de/oe-40200/2024/10/velektronik-graph-clean/region/wdQ30.ttl#>
PREFIX vann:     <http://purl.org/vocab/vann/>
PREFIX voaf:     <http://purl.org/vocommons/voaf#>
PREFIX wd:       <http://www.wikidata.org/entity/>
PREFIX wdt:      <http://www.wikidata.org/prop/direct/>
PREFIX we:       <https://welektronik.iis.fraunhofer.de/entity/>
PREFIX wfs:      <http://www.opengis.net/wfs/2.0>
PREFIX wgs:      <http://www.w3.org/2003/01/geo/wgs84_pos#>
PREFIX wgs1:     <http://www.w3.org/2003/01/geo/wgs84_pos#>
PREFIX xsd:      <http://www.w3.org/2001/XMLSchema#>

:continent  rdfs:domain     org:Organization;
        rdfs:range          wd:Q5107;
        rdfs:subPropertyOf  sn:abstractSubstitute .

:ContinentLevel  rdf:type            sn:AbstractionLevel;
        sn:discriminativeProperties  :continent_export , :continent_import .

:continent_export  rdfs:range  wd:Q5107;
        rdfs:subPropertyOf  sn:from .

:continent_import  rdfs:range  wd:Q5107;
        rdfs:subPropertyOf  sn:into .

:OrgTypeLevel  rdf:type              sn:AbstractionLevel;
        sn:discriminativeProperties  :provider , :receiver .

:provider  rdfs:range       sb:OrganizationType;
        rdfs:subPropertyOf  sn:from .

:receiver  rdfs:range       sb:OrganizationType;
        rdfs:subPropertyOf  sn:into .

:CountryLevel  rdf:type              sn:AbstractionLevel;
        sn:discriminativeProperties  :export , :import .

:export  rdfs:range         :Country;
        rdfs:subPropertyOf  sn:from .

:import  rdfs:range         :Country;
        rdfs:subPropertyOf  sn:into .

<https://aharth.solidcommunity.net/profile/card#me>
        foaf:name  "Andreas Harth" .

sn:level  rdf:type          rdf:Property;
        rdfs:comment        "Links the abstraction level of a directed supply flow."@en;
        rdfs:domain         sn:SupplyFlow;
        rdfs:isDefinedBy    sn:;
        rdfs:label          "level"@en;
        rdfs:range          sn:AbstractionLevel;
        rdfs:subPropertyOf  qb:sliceStructure .

sn:discriminativeProperty
        rdf:type            rdf:Property;
        rdfs:comment        "Links an abstraction-specific subproperty of sn:from or sn:into that is discriminative for the abstraction level. Similar to owl:hasKey, but determines an instance's keys via its sn:level relation instead of class."@en;
        rdfs:domain         sn:AbstractionLevel;
        rdfs:isDefinedBy    sn:;
        rdfs:label          "discriminative property"@en;
        rdfs:range          qb:DimensionProperty;
        rdfs:subPropertyOf  qb:componentProperty .

:Country  rdfs:subClassOf  sn:Entity , geonames:Feature .

:registeredInCountry  rdfs:domain  org:Organization;
        rdfs:range          :Country;
        rdfs:subPropertyOf  sn:abstractSubstitute .

sn:AbstractionLevel  rdf:type  rdfs:Class;
        rdfs:comment      "An abstraction level of a supply flow, identified via abstraction-specific subproperties of sn:from and sn:into."@en;
        rdfs:isDefinedBy  sn:;
        rdfs:label        "Abstraction Level"@en;
        rdfs:subClassOf   qb:SliceKey .

:EnterpriseLevel  rdf:type           sn:AbstractionLevel;
        sn:discriminativeProperties  sb:customer , sb:supplier .

sb:OrganizationType  rdfs:subClassOf  sn:Entity .

sb:organizationType  rdfs:domain  org:Organization;
        rdfs:range          sb:OrganizationType;
        rdfs:subPropertyOf  sn:abstractSubstitute .

sb:customer  rdfs:range     org:Organization;
        rdfs:subPropertyOf  sn:into .

sb:supplier  rdfs:range     org:Organization;
        rdfs:subPropertyOf  sn:from .

<https://solid.iis.fraunhofer.de/oe-40200/2024/10/velektronik-graph-clean/region/wdQ408.ttl#this>
