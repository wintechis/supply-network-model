# Example abstraction-specific terms

# The terms in this document are used to implement demonstration examples for the Supply Network Abstraction Pattern Ontology (SNAPO).
# The terms were not curated with the carefulness of a high-quality ontology.

@prefix : <https://purl.org/supply-network/examples/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sb: <https://purl.org/supplybench#> .
@prefix sn: <https://purl.org/supply-network/onto#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .

# EnterpriseLevel
:EnterpriseLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties sb:supplier , sb:customer .

# CountryLevel
:Country rdfs:subClassOf sn:Entity .
:import rdfs:subPropertyOf sn:into ;
    rdfs:range :Country .
:export rdfs:subPropertyOf sn:from ;
    rdfs:range :Country .
:CountryLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :import , :export .

# OrgTypeLevel
:receiver rdfs:subPropertyOf sn:into ;
    rdfs:range sb:OrganizationType .
:provider rdfs:subPropertyOf sn:from ;
    rdfs:range sb:OrganizationType .
:OrgTypeLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :receiver , :provider .

# ContinentLevel
:continent_import rdfs:subPropertyOf sn:into ;
    rdfs:range wd:Q5107 .
:continent_export rdfs:subPropertyOf sn:from ;
    rdfs:range wd:Q5107 .
:ContinentLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :continent_import , :continent_export .

# StateLevel
:State rdfs:subClassOf sn:Entity .
:state_import rdfs:subPropertyOf sn:into ;
    rdfs:range :State .
:state_export rdfs:subPropertyOf sn:from ;
    rdfs:range :State .
:StateLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :state_import , :state_export .

# IndustryLevel
:Industry rdfs:subClassOf sn:Entity .
:demand rdfs:subPropertyOf sn:into ;
    rdfs:range :Industry .
:supply rdfs:subPropertyOf sn:from ;
    rdfs:range :Industry .
:IndustryLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :demand , :supply .

# ProductTypeLevel
:ProductType rdfs:subClassOf sn:Entity .
:input rdfs:subPropertyOf sn:into ;
    rdfs:range :ProductType .
:output rdfs:subPropertyOf sn:from ;
    rdfs:range :ProductType .
:ProductTypeLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :input , :output .

# combined levels
:CountryOrgTypeLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :import , :export , :receiver , :provider .
:StateIndustryLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :state_import , :state_export , :demand , :supply .
:CountryIndustryLevel a sn:AbstractionLevel ;
    sn:discriminativeProperties :import , :export , :demand , :supply .

# abstract substitutes
:registeredInCountry rdfs:subPropertyOf sn:abstractSubstitute ;
    rdfs:domain org:Organization ;
    rdfs:range :Country .
:inContinent rdfs:subPropertyOf sn:abstractSubstitute ;
    rdfs:domain :Country ;
    rdfs:range wd:Q5107 .
:continent rdfs:subPropertyOf sn:abstractSubstitute ;
    rdfs:domain org:Organization ;
    rdfs:range wd:Q5107 .
wdt:P30 rdfs:subPropertyOf sn:abstractSubstitute ;
    rdfs:domain :Country ;
    rdfs:range wd:Q5107 .
:continent rdfs:subPropertyOf sn:abstractSubstitute ;
    rdfs:domain org:Organization ;
    rdfs:range wd:Q5107 .
:inCountry rdfs:subPropertyOf sn:abstractSubstitute ;
    rdfs:domain :State ;
    rdfs:range :Country .
    